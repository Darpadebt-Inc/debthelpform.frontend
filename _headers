# Content-Security-Policy is deployed in Report-Only mode first: it captures violations
# without blocking any revenue-critical payload, so lead-gen uptime is unaffected while
# the allowlist is validated against real traffic. Keeps 'unsafe-inline' so existing
# inline scripts/styles keep working. The GoHighLevel/LeadConnector embed has been
# removed, so the remaining third parties are only Bing UET (bat.bing.com) and Google
# Fonts. bat.js is a mutable vendor script, so SRI is intentionally not pinned (a pinned
# hash would break on the vendor's next release). Once violation reports are clean,
# rename the header to Content-Security-Policy to enforce.
/*
  Content-Security-Policy-Report-Only: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; script-src 'self' 'unsafe-inline' https://bat.bing.com; connect-src 'self' https://bat.bing.com https://debthelpform.com https://formsubmit.co; frame-src 'self'; form-action 'self' https://formsubmit.co; report-uri /api/mesh/015-telemetry-collector/csp-report; report-to csp-endpoint; upgrade-insecure-requests
  Reporting-Endpoints: csp-endpoint="https://debthelpform.com/api/mesh/015-telemetry-collector/csp-report"
  X-Content-Type-Options: nosniff
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Frame-Options: DENY
  Referrer-Policy: no-referrer
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), microphone=(), payment=(), usb=()
  Cache-Control: public, max-age=0, must-revalidate

/blog.index.html
  Cache-Control: no-cache, must-revalidate

# Blog feed JSON — cross-origin readable (network-wide parity with debtreliefguard;
# supports preview/proxy render paths that fetch the feed by absolute origin URL).
/blogs.json
  Cache-Control: no-store, must-revalidate
  Content-Type: application/json; charset=utf-8
  Vary: Accept, Origin
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET, OPTIONS
  Access-Control-Allow-Headers: *

/blog/*
  Cache-Control: public, max-age=300
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET, OPTIONS
  Access-Control-Allow-Headers: *

/content/blog/*
  Cache-Control: public, max-age=300

# === Unified performance baseline: immutable static assets (1 year) ===
/images/*
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

